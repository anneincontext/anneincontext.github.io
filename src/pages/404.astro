---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found" description="这个页面没有找到。">
  <section class="page-heading">
    <p class="eyebrow">404</p>
    <h1>页面没有找到</h1>
    <p>可能是旧链接已经变化，或者这个页面还没有被创建。可以回到博客归档继续浏览。</p>
    <div class="hero-actions">
      <a class="button primary" href="/blog/">Go to Blog</a>
      <a class="button" href="/">Home</a>
    </div>
  </section>
</BaseLayout>
