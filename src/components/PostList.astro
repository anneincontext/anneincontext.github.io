---
import { formatDate, getPostPath, isExternalPostPath } from '../lib/posts';
import type { Lang } from '../lib/locales';

interface Props {
  posts: Array<{
    id: string;
    data: {
      title: string;
      description: string;
      date: Date;
      tags: string[];
      category: string;
      postType: 'professional' | 'personal';
      lang: Lang;
      legacyPath?: string;
    };
  }>;
}

const { posts } = Astro.props;
const lang = posts[0]?.data.lang ?? 'en';
const sortLabel = lang === 'zh' ? '最新在前' : 'Newest first';
const sortNextLabel = lang === 'zh' ? '最早在前' : 'Oldest first';
---

<div class="podcast-toolbar">
  <button
    class="podcast-sort-button"
    type="button"
    data-sort-button
    data-sort-list="[data-blog-list]"
    data-order="desc"
    data-desc-label={sortLabel}
    data-asc-label={sortNextLabel}
  >
    {sortLabel}
  </button>
</div>
<div class="post-list" data-blog-list>
  {posts.map((post) => (
    <article class="post-card" data-published-at={post.data.date.toISOString()}>
      <div class="post-title-line">
        {(() => {
          const href = getPostPath(post);
          const isExternal = isExternalPostPath(href);

          return (
            <h3>
              <a href={href} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined}>
                {post.data.title}
              </a>
            </h3>
          );
        })()}
        <span class="post-kind">{post.data.postType}</span>
      </div>
      <footer>
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date, post.data.lang)}</time>
      </footer>
    </article>
  ))}
</div>
